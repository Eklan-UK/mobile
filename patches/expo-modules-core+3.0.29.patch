+) {
+  // type is an alias for format
+  val type: Int get() = format
+  
+  // Calculate bounding box from corner points
+  val boundingBox: BoundingBox
+    get() {
+      if (cornerPoints.isEmpty()) {
+        return BoundingBox(0, 0, 0, 0)
+      }
+      var minX = Int.MAX_VALUE
+      var minY = Int.MAX_VALUE
+      var maxX = Int.MIN_VALUE
+      var maxY = Int.MIN_VALUE
+      
+      for (i in cornerPoints.indices step 2) {
+        val x = cornerPoints[i]
+        val y = cornerPoints[i + 1]
+        minX = minOf(minX, x)
+        minY = minOf(minY, y)
+        maxX = maxOf(maxX, x)
+        maxY = maxOf(maxY, y)
+      }
+      
+      return BoundingBox(
+        x = minX,
+        y = minY,
+        width = maxX - minX,
+        height = maxY - minY
+      )
+    }
+  
+  data class BoundingBox(
+    val x: Int,
+    val y: Int,
+    val width: Int,
+    val height: Int
+  )
+}
