{
  "expo": {
    "name": "Eklan",
    "slug": "mobile",
    "version": "1.2.6",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon.png",
    "scheme": "elkan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "updates": {
      "url": "https://u.expo.dev/74671476-d20e-46aa-88fb-6dba53dbea27",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.eklan.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "We need access to your camera to record videos for your future self messages and profile pictures.",
        "NSMicrophoneUsageDescription": "This app requires microphone access to listen to your speech and provide real-time AI feedback on your speaking skills.",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to allow you to upload profile pictures and select videos.",
        "NSPhotoLibraryAddUsageDescription": "We need access to save images to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "5"
    },
    "android": {
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.eklan.ai",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/splash-icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to record videos for your future self messages and profile pictures.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to analyze your pronunciation and give you real-time feedback on your speaking skills, we need access to your microphone. Your voice data is used solely to power your practice sessions.",
          "recordAudioAndroid": true
        }
      ],
      "react-native-iap",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "kotlinVersion": "2.1.20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74671476-d20e-46aa-88fb-6dba53dbea27"
      }
    },
    "owner": "algoredeem"
  }
}
